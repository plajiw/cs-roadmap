@model IEnumerable<ProjetoMVC.Models.Produto>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Produtos</title>
</head>
<body>
    <h1>Lista de Produtos</h1>
    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Nome</th>
                <th>Categoria</th>
                <th>Preço</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var produto in Model)
            {
                <tr>
                    <td>@produto.Id</td>
                    <td>@produto.Nome</td>
                    <td>@produto.Categoria</td>
                    <td>@produto.Preco.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>