@model IEnumerable<Produto>

@{
    ViewData["Title"] = "Produtos";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="fw-bold text-primary">@ViewBag.Message</h1>
            <p class="text-muted">Bem-vindo ao nosso catálogo!</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered">
                    <thead class="table-primary">
                        <tr>
                            <th>#</th>
                            <th>Nome</th>
                            <th>Categoria</th>
                            <th>Preço</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var produto in Model)
                        {
                            <tr>
                                <td>@produto.ProdutoId</td>
                                <td>@produto.Nome</td>
                                <td><span class="badge bg-info">@produto.Categoria</span></td>
                                <td class="fw-bold text-success">@produto.Preco.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>