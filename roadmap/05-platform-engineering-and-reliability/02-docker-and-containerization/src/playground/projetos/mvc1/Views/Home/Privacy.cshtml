@{
    ViewData["Title"] = "Política de Privacidade";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1 class="fw-bold text-primary mb-4">@ViewData["Title"]</h1>
            
            <section class="mb-4">
                <h3 class="text-secondary">Sobre Privacidade</h3>
                <p>Sua privacidade é importante para nós. Esta página detalha como coletamos, usamos e protegemos suas informações pessoais.</p>
            </section>

            <section class="mb-4">
                <h3 class="text-secondary">Coleta de Dados</h3>
                <p>Apenas coletamos informações necessárias para melhorar sua experiência de compra e navegação em nosso site.</p>
            </section>

            <section class="mb-4">
                <h3 class="text-secondary">Proteção de Dados</h3>
                <p>Utilizamos criptografia e outras medidas de segurança para proteger seus dados pessoais contra acesso não autorizado.</p>
            </section>

            <section class="mb-4">
                <h3 class="text-secondary">Contato</h3>
                <p>Para dúvidas sobre nossa política de privacidade, você pode entrar em contato conosco através do nosso site.</p>
            </section>
        </div>
    </div>
</div>
